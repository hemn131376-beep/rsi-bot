# ── الأسرار المطلوبة ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=ضع_توكن_البوت_من_BotFather
TELEGRAM_CHAT_ID=معرّف_الدردشة_أو_القناة
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── اختياري (لها قيم افتراضية في config.js) ───────────────────
# مسار قائمة الحلال
WHITELIST_PATH=data/halal_whitelist.csv
# الحدّ الأدنى لحجم 24س بالدولار (فلتر السيولة)
MIN_VOLUME_USD=75000
# الفاصل بين طلبات بذر REST بالميلي ثانية (ارفعه لو واجهت حظراً)
SEED_DELAY_MS=150
# DEBUG=1 لسجلّات تفصيلية
# NO_DB=1 لتشغيل تجريبي محليّ بلا Postgres (الحالة لا تنجو من إعادة التشغيل)
